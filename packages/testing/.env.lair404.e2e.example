# lair404 E2E Test Environment
# Copy to .env.lair404.e2e and fill in values

# === Service URLs (defaults for lair404 localhost) ===
FRONTEND_URL=http://127.0.0.1:3050
SERVER_URL=http://127.0.0.1:3051
MCP_EMAIL_URL=http://127.0.0.1:5008
MCP_GWS_URL=http://127.0.0.1:5009
LITELLM_URL=http://127.0.0.1:4000
LANGFUSE_URL=http://127.0.0.1:3032
IMAP_PROXY_URL=http://127.0.0.1:3060
PG_HOST=127.0.0.1
PG_PORT=5436

# === API Keys ===
MCP_EMAIL_API_KEY=           # MCP email server API key
MCP_GWS_API_KEY=             # Google Workspace MCP API key
LITELLM_API_KEY=             # LiteLLM virtual key (sk-...)
LITELLM_MASTER_KEY=          # LiteLLM master key (for /key/info)
LANGFUSE_PUBLIC_KEY=         # Langfuse public key (pk-lf-...)
LANGFUSE_SECRET_KEY=         # Langfuse secret key (sk-lf-...)

# === Playwright Auth ===
PLAYWRIGHT_SESSION_TOKEN=    # Better Auth session token from DB (raw, unsigned)
BETTER_AUTH_SECRET=          # Better Auth secret (for HMAC-SHA256 cookie signing)
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3050

# === Test Email ===
EMAIL=mail@lair404.xyz       # Default test email for send/reply tests

# === GWS Test Config ===
GWS_TEST_FOLDER_ID=          # Google Drive folder ID for test file operations (optional)
