# Mail-Zero Production Environment (lair404)
# Copy to /opt/weretrade/mail-zero/.env on lair404 (never commit secrets)
# Last updated: 2026-02-21

# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=mailzero
POSTGRES_PASSWORD=<generate: openssl rand -base64 32>
POSTGRES_DB=mailzero

# ─── Redis (Upstash-compatible proxy) ────────────────────────────────────────
REDIS_URL=http://mail-zero-upstash-proxy:80
REDIS_TOKEN=<generate: openssl rand -base64 32>

# ─── Better Auth ─────────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=<generate: openssl rand -hex 32>
BETTER_AUTH_URL=https://mail.lair404.xyz
COOKIE_DOMAIN=mail.lair404.xyz

# ─── Cloudflare Access ───────────────────────────────────────────────────────
# Get from Cloudflare Zero Trust → Access → Applications → mail.lair404.xyz → AUD tag
CF_ACCESS_AUD=0ee5c7027b7b7a5b4c21e1b48fdb5f19583b307b664a4ef27219a71090e91c8b
CF_ACCESS_TEAM_DOMAIN=lair404

# ─── IMAP/SMTP (local mailserver, network_mode: host) ────────────────────────
# Use 127.0.0.1, NOT mail.lair404.xyz (Cloudflare proxies that domain — no IMAP/SMTP)
IMAP_URL=imaps://mail%40lair404.xyz:<password>@127.0.0.1:993
SMTP_URL=smtps://mail%40lair404.xyz:<password>@127.0.0.1:465

# ─── Google OAuth (for Gmail connections) ────────────────────────────────────
# Create at https://console.cloud.google.com/ → OAuth 2.0
# Authorized redirect URI: https://mail.lair404.xyz/api/gmail/callback
GOOGLE_CLIENT_ID=<google-oauth-client-id>
GOOGLE_CLIENT_SECRET=<google-oauth-client-secret>

# ─── LiteLLM AI Agent ────────────────────────────────────────────────────────
# Virtual key created at litellm.lair404.xyz (mail-zero-ai-agent, $20/30d budget)
LITELLM_BASE_URL=http://127.0.0.1:4000/v1
# Generate at litellm.lair404.xyz → Virtual Keys (allowed models: mistral-large-latest, llama)
LITELLM_VIRTUAL_KEY=<litellm-virtual-key>
LITELLM_MODEL=mistral-large-latest

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://mail.lair404.xyz

# ─── LLM placeholder keys (routed through LiteLLM above) ────────────────────
# NOTE: OPENAI_MODEL/OPENAI_MINI_MODEL are fallbacks picked up by upstream Zero code.
# They MUST match model aliases registered in LiteLLM — NOT raw OpenAI model names.
GROQ_API_KEY=placeholder_will_use_litellm
OPENAI_API_KEY=placeholder_will_use_litellm
OPENAI_MODEL=mistral-large-latest
OPENAI_MINI_MODEL=mistral-small-latest

# ─── AI System Prompt ────────────────────────────────────────────────────────
AI_SYSTEM_PROMPT="You are a helpful email assistant for lair404.xyz mail system."

# ─── MCP Server (Model Context Protocol) ──────────────────────────────────
# Port 5008 (see port registry), transport sse
MCP_TRANSPORT=sse
PORT_MCP=5008
MCP_API_KEY=08995ca847bfd051fcdc855d835fe8489f14d33495ff9def9dc15adbbf333c7c
MAIL_ZERO_USER_EMAIL=florian.scheugenpflug@lair404.xyz

# ─── Google Workspace MCP (Calendar, Drive, Docs, Sheets) ───────────────────
# Port 5009, streamable-http transport
# Reuses GOOGLE_CLIENT_ID/SECRET from above (same OAuth app)
# Generate refresh token: see DEPLOYMENT-LAIR404.md § Google Workspace MCP Setup
GOOGLE_OAUTH_CLIENT_ID=${GOOGLE_CLIENT_ID}
GOOGLE_OAUTH_CLIENT_SECRET=${GOOGLE_CLIENT_SECRET}
GOOGLE_REFRESH_TOKEN=<from-oauth-flow>
GWS_MCP_API_KEY=<generate: openssl rand -hex 32>

# ─── Optional services (disabled) ───────────────────────────────────────────
RESEND_API_KEY=
PERPLEXITY_API_KEY=
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=
NEXT_PUBLIC_IMAGE_PROXY=
NEXT_PUBLIC_IMAGE_API_URL=
USE_OPENAI=true
