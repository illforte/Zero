# Mail-Zero Production Environment (n1njanode.com)
# Last updated: 2026-02-24

# ── PostgreSQL ─────────────────────────────────────────────────────────────────
POSTGRES_USER=mailzero
POSTGRES_PASSWORD=generate_manually_if_needed
POSTGRES_DB=mailzero

# ── Redis / Upstash proxy ──────────────────────────────────────────────────────
REDIS_URL=redis://mail-zero-valkey:6379
REDIS_TOKEN=generate_manually_if_needed

# ── Auth (better-auth) ────────────────────────────────────────────────────────
BETTER_AUTH_SECRET=generate_manually_if_needed
BETTER_AUTH_URL=https://mail-api.n1njanode.com
COOKIE_DOMAIN=.n1njanode.com

# ── Cloudflare Access JWT validation ─────────────────────────────────────────
# Get AUD from: CF Zero Trust → Access → Applications → mail-api.n1njanode.com → Overview
CF_ACCESS_AUD=cf-access-application-aud-token-placeholder
CF_ACCESS_TEAM_DOMAIN=weretrade.cloudflareaccess.com

# ── IMAP / SMTP ───────────────────────────────────────────────────────────────
# n1njanode hosts Dovecot/Postfix locally — connect to 127.0.0.1
IMAP_URL=imaps://admin@n1njanode.com:password-placeholder@127.0.0.1:993
SMTP_URL=smtps://admin@n1njanode.com:password-placeholder@127.0.0.1:465

# ── Google OAuth (better-auth social login) ───────────────────────────────────
GOOGLE_CLIENT_ID=google-oauth-client-id-placeholder
GOOGLE_CLIENT_SECRET=google-oauth-client-secret-placeholder

# ── LiteLLM (n1njanode local instance) ───────────────────────────────────────
# n1njanode runs its own LiteLLM on port 4000
LITELLM_BASE_URL=http://127.0.0.1:4000/v1
LITELLM_VIRTUAL_KEY=sk-n1nja-mail-zero-placeholder
LITELLM_MODEL=llama-3.3-70b

# ── MCP Server (Model Context Protocol) ──────────────────────────────────
# Port 5008, transport sse
MCP_TRANSPORT=sse
PORT_MCP=5008
MCP_API_KEY=aa2a19a2233e7bae90cd8fcf90aa1657b637065e123d61e321a7a3f5c18590a0
MAIL_ZERO_USER_EMAIL=admin@n1njanode.com

# ── AI features ─────────────────
OPENAI_MODEL=mistral-large-latest
OPENAI_MINI_MODEL=mistral-small-latest
AI_SYSTEM_PROMPT="You are a helpful email assistant for n1njanode.com mail system."

# ── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://mail.n1njanode.com,https://mail-api.n1njanode.com
\nUSE_OPENAI=true
